{
	"compilerOptions": {
		"target": "es2023",
		"lib": ["ES2023"],
		"module": "esnext",
		"moduleResolution": "bundler",
		"moduleDetection": "force",
		"verbatimModuleSyntax": true,
		"skipLibCheck": true,
		"strict": true,
		"noEmit": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noFallthroughCasesInSwitch": true,
		"erasableSyntaxOnly": true
	}
}
