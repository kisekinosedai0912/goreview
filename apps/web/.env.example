# --- GitHub App (webhooks, check runs, installation tokens) ---
GITHUB_APP_ID=
# PEM contents; newlines may be escaped as \n
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# --- GitHub OAuth (user sign-in; use the App's client id/secret) ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Session cookie encryption (any long random string) ---
SESSION_SECRET=

# --- Public URL of this deployment (used in PR comments / check links) ---
APP_URL=http://localhost:3000

# --- Optional snapshot cache (Upstash Redis / Vercel KV) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Opt-in Review Intelligence (Vercel AI Gateway) ---
# Verified against the live Gateway catalog during implementation.
AI_REVIEW_MODEL=openai/gpt-5.6-sol
# Do not commit or put this in Terraform. Vercel injects it in deployments;
# `vercel env pull .env.local` creates a short-lived token for local dev.
VERCEL_OIDC_TOKEN=

# --- Local development fallbacks (no App / OAuth needed) ---
# Personal access token used when no session or installation matches:
# Inline comments need Pull requests: read/write. AI actions require an
# attributable signed-in user or this local token.
GITHUB_TOKEN=
# Serve public repos unauthenticated (60 req/h shared limit; dev only):
ALLOW_ANONYMOUS_GITHUB=
