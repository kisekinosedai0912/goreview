{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"lib": ["ES2023", "DOM", "DOM.Iterable"],
		"jsx": "preserve",
		"types": ["node", "react", "react-dom"],
		"allowJs": true,
		"incremental": true,
		"erasableSyntaxOnly": false,
		"paths": {
			"@/*": ["./src/*"]
		},
		"plugins": [{ "name": "next" }]
	},
	"include": [
		"next-env.d.ts",
		"app/**/*.ts",
		"app/**/*.tsx",
		"src/**/*.ts",
		"src/**/*.tsx",
		".next/types/**/*.ts"
	],
	"exclude": ["node_modules"]
}
