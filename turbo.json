{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": [
				"dist/**",
				".next/**",
				"!.next/cache/**",
				".output/**"
			]
		},
		"typecheck": {},
		"lint": {},
		"test": {},
		"dev": {
			"cache": false,
			"persistent": true
		}
	}
}
